# OS/editor noise
.DS_Store
*.swp
*.swo

# Runtime logs and temp files
*.log
tmp/
log/

# Local secrets and environment
.env
.env.*
!.env.example
*.local

# Ruby/Rails crawler runtime
crawler/.bundle/
crawler/vendor/bundle/
crawler/log/
