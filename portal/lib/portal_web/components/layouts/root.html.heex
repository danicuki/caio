<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="description" content={PortalWeb.PageHTML.meta_description(assigns)} />
    <meta name="theme-color" content="#0E5C49" />
    <link rel="canonical" href={PortalWeb.PageHTML.canonical_url(assigns)} />
    <meta property="og:site_name" content="Caio" />
    <meta property="og:type" content={assigns[:og_type] || "website"} />
    <meta property="og:title" content={PortalWeb.PageHTML.meta_title(assigns)} />
    <meta property="og:description" content={PortalWeb.PageHTML.meta_description(assigns)} />
    <meta property="og:url" content={PortalWeb.PageHTML.canonical_url(assigns)} />
    <meta property="og:image" content={PortalWeb.PageHTML.og_image_url(assigns)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={PortalWeb.PageHTML.meta_title(assigns)} />
    <meta name="twitter:description" content={PortalWeb.PageHTML.meta_description(assigns)} />
    <meta name="twitter:image" content={PortalWeb.PageHTML.og_image_url(assigns)} />
    <.live_title default="Caio" suffix=" · Caio" phx-no-format>{assigns[:page_title]}</.live_title>
    <link rel="icon" href={~p"/images/caio-mark.svg"} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={~p"/images/caio-apple-touch.png"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <%= if posthog_config = Portal.Analytics.browser_config() do %>
      <script>
        window.caioPosthogConfig = <%= raw(Jason.encode!(posthog_config)) %>;
      </script>
    <% end %>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        document.addEventListener("DOMContentLoaded", () => {
          document
            .querySelectorAll("button[data-phx-theme]")
            .forEach((el) => {
              el.addEventListener("click", () => {
                setTheme(el.dataset.phxTheme);
                if (window.posthog && window.posthog.capture) {
                  window.posthog.capture("theme_changed", { theme: el.dataset.phxTheme });
                }
              })
            })
        })
      })();
    </script>
  </head>
  <body data-analytics-distinct-id={assigns[:analytics_distinct_id]}>
    {@inner_content}
    <%= if chat_config = Portal.FounderChat.widget_config() do %>
      <aside
        class="founder-chat"
        data-founder-chat
        data-title={chat_config.title}
        data-subtitle={chat_config.subtitle}
        hidden
      >
        <button class="founder-chat-button" type="button" data-chat-toggle aria-expanded="false">
          Chat
        </button>
        <section class="founder-chat-panel" aria-label="Founder chat">
          <header>
            <div>
              <strong>{chat_config.title}</strong>
              <span>{chat_config.subtitle}</span>
            </div>
            <button type="button" data-chat-close aria-label="Close chat">×</button>
          </header>
          <div class="founder-chat-messages" data-chat-messages>
            <p class="founder-chat-empty">Ask a question or tell me what feels broken.</p>
          </div>
          <form class="founder-chat-form" data-chat-form>
            <textarea
              name="body"
              rows="2"
              maxlength="4000"
              placeholder="Type your message..."
              required
            ></textarea>
            <button type="submit">Send</button>
          </form>
        </section>
      </aside>
    <% end %>
    <.flash_group flash={@flash} />
  </body>
</html>
